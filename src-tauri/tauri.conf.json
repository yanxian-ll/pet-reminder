{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "桌宠提醒休息",
  "version": "0.1.0",
  "identifier": "com.yanxianll.deskpetrestreminder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "桌宠提醒休息",
        "width": 236,
        "height": 236,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "桌宠提醒设置",
        "width": 560,
        "height": 760,
        "minWidth": 460,
        "minHeight": 560,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#f1f5f9",
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    }
  }
}
